APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
LOG_CHANNEL=stack
LOG_LEVEL=debug
#LOG_LEVEL=stderr

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=dev
DB_USERNAME=dev
DB_PASSWORD=dev

VECTOR_DB_CONNECTION=pgsql
VECTOR_DB_HOST=pgvector
VECTOR_DB_PORT=5432
VECTOR_DB_DATABASE=dev
VECTOR_DB_USERNAME=dev
VECTOR_DB_PASSWORD=dev

WP_DB_CONNECTION=mysql
WP_DB_HOST=172.23.189.118
WP_DB_DATABASE=wordpress
WP_DB_USERNAME=wordpress
WP_DB_PASSWORD=wordpress
WP_DB_TABLE_PREFIX=wp_
WP_DB_CHARSET=utf8mb4
WP_DB_COLLATION=utf8mb4_unicode_ci

SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_DRIVER=file
QUEUE_CONNECTION=sync

VITE_APP_NAME="${APP_NAME}"

EMBEDDING_PROVIDER=huggingface #huggingface | openai
LLM_PROVIDER=groq #groq | openai

HUGGINGFACE_API_KEY=
HUGGINGFACE_EMBEDDING_MODEL=intfloat/multilingual-e5-large
HUGGINGFACE_EMBEDDING_MODEL_DIMENSIONS=1024

GROQ_API_KEY=
GROQ_LLM_MODEL=llama-3.1-8b-instant
GROQ_LLM_MODEL_TEMPERATURE=0.1
GROQ_LLM_MODEL_MAX_OUTPUT_TOKENS=1024

OPENAI_API_KEY=
OPENAI_ORGANIZATION=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_MODEL_DIMENSIONS=1536
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_LLM_MODEL_TEMPERATURE=0.1
OPENAI_LLM_MODEL_MAX_OUTPUT_TOKENS=1024

RAG_CHARS_PER_TOKEN=2.7
RAG_MAX_CONTEXT_TOKENS=6000
RAG_MAX_VECTOR_DISTANCE=0.45
RAG_MAX_RETRIEVAL_CHUNKS=4
RAG_MIN_RFF_SCORE=0.015
RAG_RFF_K_VALUE=60
RAG_MAX_RECENT_CONVERSATION_HISTORY=3
RAG_INGEST_MAX_WORDS=500
RAG_INGEST_OVERLAP_WORDS=50
    
ADMIN_NAME="System Administrator"
ADMIN_EMAIL=admin@test.com
ADMIN_PASSWORD=123456

ENABLE_LOCAL_WIDGET=true
LOCAL_WIDGET_TOKEN=local_widget_token_123456

LLM_DEFAULT_SYSTEM_PROMPT="Você é um assistente virtual especialista no sistema ERP Transnet. Seu objetivo é responder às dúvidas dos usuários com base EXCLUSIVAMENTE nos fragmentos de documentos fornecidos abaixo.
REGRAS OBRIGATÓRIAS E FORMATAÇÃO:
- Sempre que você utilizar uma informação de um bloco de contexto para responder ao usuário, você DEVE incluir o link da 'Fonte' correspondente logo após a afirmação, além de sempre utilizar o título do post como nome do link(ex: [Título do Post](url_da_fonte)).
- Nunca invente URLs. Use estritamente as URLs fornecidas dentro das tags de contexto.
- Seja direto, claro e profissional.
- Se a resposta não puder ser extraída do contexto fornecido, responda honestamente que não possui essa informação.
- Se nada relacionado à pergunta for fornecido no contexto, informe ao usuário e responda dando sugestão de reformular."

LLM_FALLBACK_SYSTEM_PROMPT="Você é um assistente virtual especialista em UX (Experiência do Usuário) e suporte técnico de sistemas.
O usuário fez uma pergunta, mas não encontramos documentos específicos no nosso banco de dados RAG para respondê-la diretamente. 
Sua tarefa é agir como um guia dinâmico:
1. Explique brevemente ao usuário que você não localizou um artigo exato sobre o assunto.
2. Analise a lista de categorias e subcategorias disponíveis fornecidas nos 'Dados de Entrada'.
3. Com base na pergunta atual do usuário, recomende em qual dessas subcategorias ele provavelmente encontrará a resposta ou onde ele deve clicar no sistema para resolver o problema dele.
4. Mantenha um tom profissional, corporativo, direto e extremamente amigável em português do Brasil."

LLM_QUERY_REWRITER_SYSTEM_PROMPT="Você é um otimizador de buscas para sistemas RAG. 
Sua única tarefa é analisar o histórico da conversa e a última mensagem do usuário para gerar uma **pergunta autônoma, clara e completa em português do Brasil**.
Regras que DEVEM ser seguidas:
1. Resolva pronomes e ambiguidades (ex: 'ele', 'disso', 'me refiro a X') com base no histórico.
2. Formule como uma pergunta direta de busca (ex: 'Como localizar/cadastrar X?'').
3. Retorne APENAS a frase reescrita, sem explicações, saudações ou pontuações extras."
    {
      "parameters": {
        "jsCode": "const context = $input.first().json.data\n\nconst system_prompt = `Você é um engenheiro de QA (Garantia de Qualidade) testando um chatbot RAG. \nSeu trabalho é ler o fragmento de documentação fornecido e gerar exatamente 3 perguntas de teste diversificadas.\n- Pergunta 1: Uma pergunta direta usando palavras-chave exatas extraídas do texto.\n- Pergunta 2: Uma pergunta conceitual usando sinônimos (sem usar as palavras-chave exatas).\n- Pergunta 3: Uma pergunta capciosa/complexa sobre um parâmetro do sistema ou uma regra específica.\n\nRetorne APENAS um array JSON bruto de strings (ex: [\"pergunta1\", \"pergunta2\", \"pergunta3\"]). Não escreva nenhum texto de introdução ou saudação.`\n\nconst prompt = \n`# [CONTEXTO RECUPERADO / DADOS DA SEARCH]\nAbaixo estão as informações extraídas da base de conhecimento que devem ser utilizadas para gerar as perguntas.\n\n${context}\n\n---\n\n# [RESPOSTA DO ASSISTENTE]\n`;\n\nconst payload = {\n  \"model\": \"llama-3.1-8b-instant\",\n  \"messages\": [\n    { \"role\": \"system\", \"content\": system_prompt },\n    { \"role\": \"user\", \"content\": prompt }\n  ],\n  \"temperature\": 0.1,\n  \"max_tokens\": 1024\n}\n\nreturn [{payload}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        624,
        208
      ],
      "id": "6b9a395d-e1fb-4095-b261-9c41ee4f23ea",
      "name": "Code in JavaScript5"
    },
    {
      "parameters": {
        "jsCode": "let questionsArray\nconst questions = []\ntry {\n  // 2. Parse the string into a real JavaScript array\n  questionsArray = JSON.parse($input.first().json.choices[0].message.content);\n  const session = Math.floor(Math.random() * 100000) + 1\n  for (let i = 0; i < questionsArray.length; i++){\n    questions.push({question: questionsArray[i], sesionId: session})\n  }\n\n} catch (error) {\n  return [{}]\n}\n\nreturn [...questions];"
      },
